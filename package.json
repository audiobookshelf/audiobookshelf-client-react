    "hls.js": "^1.6.15",
    "marked": "^18.0.5",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-transition-group": "^4.4.5",
    "slate": "^0.118.1",
    "slate-history": "^0.113.1",
