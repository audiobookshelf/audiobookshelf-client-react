      "sharp@<0.35.0": "^0.35.0",
      "systeminformation@<=5.31.6": ">=5.31.7",
      "tar@<=7.5.18": ">=7.5.19",
      "tmp@<0.2.6": ">=0.2.6",
      "uuid@<11.1.1": ">=11.1.1",
      "ws@>=8.0.0 <8.21.0": "^8.21.0"
    }
  }
}
